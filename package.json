{
  "name": "pebble-watchface-argus",
  "version": "1.2.0",
  "author": "filcuk",
  "private": true,
  "keywords": [
    "pebble-app"
  ],
  "scripts": {
    "build:clay": "node scripts/build-custom-clay.js",
    "measure-clay": "node scripts/measure-clay-url.js --max=180000"
  },
  "dependencies": {
    "@rebble/clay": "^1.0.10"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "terser": "^5.39.0"
  },
  "pebble": {
